{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kiki054-n/oss-wee/wall-of-hands/schema/hand.schema.json",
  "title": "Hand",
  "description": "台帳に参加する主体。中央発行体は存在しない。すべてのHandは対等。",
  "type": "object",
  "required": ["hand_id", "display_name", "created_at"],
  "additionalProperties": false,
  "properties": {
    "hand_id": {
      "type": "string",
      "pattern": "^hand:[a-zA-Z0-9_-]+$",
      "description": "一意識別子。例: hand:kiki054-n"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
